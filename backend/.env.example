PORT=8080
JWT_SECRET=replace-me-with-a-long-random-string
# MongoDB Atlas / self-hosted connection string. Include the DB name in the path.
# Example: mongodb+srv://USER:PASS@cluster0.example.mongodb.net/electro?retryWrites=true&w=majority
MONGODB_URI=

# --- Optional: Firebase Cloud Messaging (push notifications) ---
# Paste the entire JSON of a Firebase Admin SDK service-account key on a single line.
# If unset, push notifications are silently skipped.
FIREBASE_ADMIN_SDK_JSON=

# --- Optional: Cloudinary (technician profile-image uploads) ---
# Required for /technician/uploads/sign to work.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=
